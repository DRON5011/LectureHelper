<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android=
    "http://schemas.android.com/apk/res/android">

    <uses-permission
        android:name="android.permission.INTERNET"/>

    <uses-permission
        android:name="android.permission.RECORD_AUDIO"/>

    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE"/>

    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:name="com.example.lecturehelper.LectureAiApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="xml/data_extraction_rules"
        android:networkSecurityConfig="xml/network_security_config"
        android:theme="style/Theme.Lecturehelper">

        <activity
            android:name="com.example.lecturehelper.MainActivity"
            android:exported="true">

            <intent-filter>

                <action
                    android:name="android.intent.action.MAIN"/>

                <category
                    android:name="android.intent.category.LAUNCHER"/>

            </intent-filter>

        </activity>
        <service
            android:name="com.example.lecturehelper.services.AudioRecordingService"
            android:foregroundServiceType="microphone"
            android:exported="false"/>

    </application>

</manifest>